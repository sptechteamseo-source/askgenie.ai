# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env.local and fill in real values
# NEVER commit .env or .env.local to git (they are gitignored)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
# MONGODB_URI is the Vercel-standard env var name; the app reads this at runtime.
# DATABASE_URL is used by the Prisma CLI (prisma generate, db push, studio).
# Both should point at the same MongoDB Atlas cluster.
# Include the database name in the URI: …mongodb.net/<dbname>?…
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate a secure random secret:  openssl rand -base64 32
AUTH_SECRET="<your-random-32-byte-base64-secret>"

# Local dev URL — NOT required in Vercel (NextAuth reads VERCEL_URL automatically)
AUTH_URL="http://localhost:3000"

# ─── Cloudinary (image uploads) ──────────────────────────────────────────────
# Create a free account at https://cloudinary.com
CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"
CLOUDINARY_CLOUD_NAME="<cloud_name>"
CLOUDINARY_API_KEY="<api_key>"
CLOUDINARY_API_SECRET="<api_secret>"

# ─── Required Vercel environment variables ────────────────────────────────────
# Set these in your Vercel project dashboard → Settings → Environment Variables:
#
#   MONGODB_URI          ← MongoDB Atlas connection string (with database name)
#   AUTH_SECRET          ← Random 32-byte secret (openssl rand -base64 32)
#   CLOUDINARY_CLOUD_NAME
#   CLOUDINARY_API_KEY
#   CLOUDINARY_API_SECRET
#
# OPTIONAL in Vercel (auto-detected):
#   AUTH_URL             ← Vercel sets VERCEL_URL; NextAuth reads it automatically
