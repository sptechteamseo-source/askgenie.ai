generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  password         String
  role             Role      @default(AUTHOR)
  image            String?
  // Author profile fields — editable from dashboard /profile
  bio              String?   // Short author bio paragraph
  jobTitle         String?   // e.g. "Director of RevOps · Northwind Capital"
  twitter          String?   // Full Twitter URL
  linkedin         String?   // Full LinkedIn URL
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  blogs            Blog[]
  useCases         UseCase[]
}

model Blog {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String?
  content        String
  coverImage     String?
  // SEO & Open Graph — editable from dashboard blog form
  ogImage        String?       // Open Graph / Twitter card image (can differ from coverImage)
  seoTitle       String?       // Overrides title in <title> tag
  seoDescription String?       // Overrides excerpt in <meta description>
  // FAQ — stored as JSON array [{q, a}] — editable from dashboard
  faq            Json?
  tag            String?
  status         Status        @default(DRAFT)
  readMin        Int           @default(5)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  authorId       String
  categoryId     String?
  author         User          @relation(fields: [authorId], references: [id])
  category       BlogCategory? @relation(fields: [categoryId], references: [id])
  tags           BlogTagMap[]
}

model BlogCategory {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  blogs Blog[]
}

model BlogTag {
  id    String       @id @default(cuid())
  name  String       @unique
  slug  String       @unique
  posts BlogTagMap[]
}

model BlogTagMap {
  blogId String
  tagId  String
  blog   Blog    @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
}

model UseCase {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  persona     String
  excerpt     String?
  content     String
  metric      String?
  industry    String?
  teamType    String?
  status      Status    @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
}

model Testimonial {
  id         String   @id @default(cuid())
  quote      String
  authorName String
  authorRole String?
  company    String?
  initials   String?
  seats      String?
  status     Status   @default(DRAFT)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum Role {
  ADMIN
  EDITOR
  AUTHOR
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}
