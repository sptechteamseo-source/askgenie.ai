generator client {
  provider = "prisma-client-js"
}

// DATABASE_URL is read by the Prisma CLI (prisma generate, db push, studio).
// At *runtime* the app resolves the connection via lib/prisma.ts which reads
// process.env.MONGODB_URI first, then falls back to DATABASE_URL.
// Set MONGODB_URI in Vercel environment variables for production deployments.
datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model users {
  id               String    @id @default(cuid()) @map("_id")
  name             String
  email            String    @unique
  password         String
  role             role      @default(author)
  image            String?
  // Author profile fields — editable from dashboard /profile
  bio              String?
  jobtitle         String?
  twitter          String?
  linkedin         String?
  resettoken       String?
  resettokenexpiry DateTime?
  createdat        DateTime  @default(now())
  updatedat        DateTime  @updatedAt
  blogs            blog[]
  usecases         usecase[]
}

model blog {
  id             String        @id @default(cuid()) @map("_id")
  title          String
  slug           String        @unique
  excerpt        String?
  content        String
  coverimage     String?
  // SEO & Open Graph — editable from dashboard blog form
  ogimage        String?
  seotitle       String?
  seodescription String?
  // FAQ — stored as JSON array [{q, a}]
  faq            Json?
  tag            String?
  status         status        @default(draft)
  readmin        Int           @default(5)
  publishedat    DateTime?
  createdat      DateTime      @default(now())
  updatedat      DateTime      @updatedAt
  authorid       String
  categoryid     String?
  author         users         @relation(fields: [authorid], references: [id])
  category       blogcategory? @relation(fields: [categoryid], references: [id])
  tags           blogtagmap[]
}

model blogcategory {
  id    String @id @default(cuid()) @map("_id")
  name  String @unique
  slug  String @unique
  blogs blog[]
}

model blogtag {
  id    String       @id @default(cuid()) @map("_id")
  name  String       @unique
  slug  String       @unique
  posts blogtagmap[]
}

model blogtagmap {
  id     String  @id @default(cuid()) @map("_id")
  blogid String
  tagid  String
  blog   blog    @relation(fields: [blogid], references: [id], onDelete: Cascade)
  tag    blogtag @relation(fields: [tagid], references: [id], onDelete: Cascade)

  @@unique([blogid, tagid])
}

model usecase {
  id          String    @id @default(cuid()) @map("_id")
  title       String
  slug        String    @unique
  persona     String
  excerpt     String?
  content     String    @default("")
  // Structured page content — mirrors the sections in each use-case page
  // Shape: { hero, explained[3], steps[4], problems[6], features[6], benefits[6], stats[4], quote, logos[12] }
  pagedata    Json?
  metric      String?
  industry    String?
  teamtype    String?
  status      status    @default(draft)
  publishedat DateTime?
  createdat   DateTime  @default(now())
  updatedat   DateTime  @updatedAt
  authorid    String
  author      users     @relation(fields: [authorid], references: [id])
}

model testimonial {
  id         String   @id @default(cuid()) @map("_id")
  quote      String
  authorname String
  authorrole String?
  company    String?
  initials   String?
  seats      String?
  status     status   @default(draft)
  order      Int      @default(0)
  createdat  DateTime @default(now())
  updatedat  DateTime @updatedAt
}

model contactsubmission {
  id        String   @id @default(cuid()) @map("_id")
  name      String
  email     String
  company   String?
  role      String?
  teamsize  String?
  message   String
  status    String   @default("new") // new | read | replied | archived
  createdat DateTime @default(now())
  updatedat DateTime @updatedAt
}

enum role {
  admin
  editor
  author
}

enum status {
  draft
  published
  archived
}
